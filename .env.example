# Copy this file to .env and fill in values

# Lighthouse
LIGHTHOUSE_PROPERTY_ID=
LIGHTHOUSE_API_KEY=
LIGHTHOUSE_BASE_URL=

# Simple Booking
SB_PROPERTY_ID=
SB_RATE_PLAN_ID=BAR
SB_API_KEY=
SB_BASE_URL=

# App
CURRENCY=EUR
DRY_RUN=true
API_BASE_URL=http://localhost:8000

# Login gate (Streamlit)
APP_USERNAME=admin
APP_PASSWORD=admin

# -------------------------------------------------------------------
# Rate shopping (competitor pricing intelligence via Apify + Supabase)
# -------------------------------------------------------------------

# Apify (server-side only — NEVER expose APIFY_TOKEN to the browser)
APIFY_TOKEN=
# Booking.com scraper actor. Accepts the "username/actor-name" or "username~actor-name" form.
APIFY_ACTOR_ID=voyager/booking-scraper
# Optional: only needed if you wire up the Apify webhook endpoint
APIFY_WEBHOOK_SECRET=

# Default currency for normalised prices
PRICING_DEFAULT_CURRENCY=EUR

# Supabase Postgres connection (server-side only).
# Use the *connection pooler* string (port 6543) from:
#   Supabase Dashboard -> Project Settings -> Database -> Connection string -> "Transaction pooler"
# Example:
#   postgresql://postgres.xdobtmfkbdgenzmtpmlv:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Cost-control safeguards (optional overrides)
RATESHOP_MAX_HORIZON_DAYS=120
RATESHOP_MAX_COMPETITORS=15
RATESHOP_MAX_DATES_PER_MANUAL_RUN=14
RATESHOP_DEDUP_WINDOW_HOURS=12